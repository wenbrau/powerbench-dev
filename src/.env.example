# Copy to `.env` and fill in the key(s) for the providers you evaluate.
# Inspect reads this file automatically from the working directory.

# Anthropic (Claude models, and recommended judge)
ANTHROPIC_API_KEY=

# OpenAI (GPT models)
OPENAI_API_KEY=

# Optional: OpenRouter as a single gateway to many providers.
# Use models as `openrouter/anthropic/claude-sonnet-4-6`, etc.
# OPENROUTER_API_KEY=
